# =============================================================================
# Review Platform Backend - SQLite Development Environment
# 使用SQLite作为开发数据库，无需安装PostgreSQL
# =============================================================================

# Application
APP_NAME=ReviewPlatform
APP_ENV=development
DEBUG=true
SECRET_KEY=dev-secret-key-do-not-use-in-production

# Server
HOST=0.0.0.0
PORT=8000
API_V1_PREFIX=/api/v1

# SQLite Database (开发环境使用)
DATABASE_URL=sqlite+aiosqlite:///./review_platform.db
DATABASE_URL_SYNC=sqlite:///./review_platform.db

# Redis (开发环境可选)
REDIS_URL=redis://localhost:6379/0

# JWT Authentication
JWT_SECRET_KEY=dev-jwt-secret-key-do-not-use-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
JWT_REFRESH_TOKEN_EXPIRE_DAYS=30

# AI Models (OpenAI) - 需要替换为实际API Key
OPENAI_API_KEY=sk-your-openai-api-key
OPENAI_MODEL=gpt-4o
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_MAX_TOKENS=4096
OPENAI_TEMPERATURE=0.7

# Celery Task Queue (开发环境可选)
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# CORS (JSON array format)
CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]

# Logging
LOG_LEVEL=DEBUG
LOG_FORMAT=json
