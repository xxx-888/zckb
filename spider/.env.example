# Redis Configuration
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# Main Backend API Configuration
API_BASE_URL=http://localhost:8000/api/v1
API_KEY=your-api-key-here

# Task Configuration
MAX_CONCURRENT_TASKS=5
TASK_TIMEOUT=300

# Playwright Configuration
PLAYWRIGHT_HEADLESS=true
PLAYWRIGHT_SLOW_MO=0
PLAYWRIGHT_BROWSER_TYPE=chromium

# Logging
LOG_LEVEL=INFO

# Database (for local task queue storage)
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/spider_db

# Platform Credentials (example)
MEITUAN_USERNAME=your_meituan_username
MEITUAN_PASSWORD=your_meituan_password
DOUYIN_USERNAME=your_douyin_username
DOUYIN_PASSWORD=your_douyin_password
TAOBAO_USERNAME=your_taobao_username
TAOBAO_PASSWORD=your_taobao_password
JD_USERNAME=your_jd_username
JD_PASSWORD=your_jd_password
